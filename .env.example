# AI GTM Engine environment template
# Copy to `.env` and fill the required secrets before starting the stack.

###############################################################################
# Database
###############################################################################
# Database name | source: local or managed Postgres | required | default: gtm_engine
POSTGRES_DB=gtm_engine
# Database user | source: local or managed Postgres | required | default: gtm
POSTGRES_USER=gtm
# Database password | source: local or managed Postgres | required | default: gtm_password
POSTGRES_PASSWORD=gtm_password
# Async database URL | source: derived from Postgres credentials | required | default: postgresql+asyncpg://gtm:gtm_password@postgres:5432/gtm_engine
DATABASE_URL=postgresql+asyncpg://gtm:gtm_password@postgres:5432/gtm_engine
# Sync database URL | source: derived from Postgres credentials | required | default: postgresql://gtm:gtm_password@postgres:5432/gtm_engine
DATABASE_SYNC_URL=postgresql://gtm:gtm_password@postgres:5432/gtm_engine
# Test database URL | source: dedicated test Postgres | optional | default: postgresql+asyncpg://gtm:gtm_password@localhost:5433/gtm_engine_test
TEST_DATABASE_URL=postgresql+asyncpg://gtm:gtm_password@localhost:5433/gtm_engine_test

###############################################################################
# Redis
###############################################################################
# Redis URL | source: local Redis or managed Redis | required | default: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
# Redis password | source: managed Redis secret | optional | default: empty
REDIS_PASSWORD=
# Redis database index | source: local configuration | optional | default: 0
REDIS_DB=0
# Celery broker URL | source: Redis | optional | default: redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/1
# Celery result backend | source: Redis | optional | default: redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2

###############################################################################
# Qdrant
###############################################################################
# Qdrant base URL | source: local Qdrant or Qdrant Cloud | required | default: http://qdrant:6333
QDRANT_URL=http://qdrant:6333
# Qdrant API key | source: Qdrant Cloud | optional | default: empty
QDRANT_API_KEY=
# Collection prefix | source: internal naming convention | optional | default: gtm_engine
QDRANT_COLLECTION_PREFIX=gtm_engine

###############################################################################
# Authentication
###############################################################################
# JWT secret | source: secret manager or local random value | required | default: change-me-in-production
JWT_SECRET=change-me-in-production
# JWT algorithm | source: internal default | optional | default: HS256
JWT_ALGORITHM=HS256
# Access token TTL in minutes | source: internal policy | optional | default: 15
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token TTL in days | source: internal policy | optional | default: 7
REFRESH_TOKEN_EXPIRE_DAYS=7
# Browser CORS allowlist | source: app origins | required | default: http://localhost:3000,http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Public frontend origin | source: deployed web URL or local compose | required | default: http://localhost
FRONTEND_ORIGIN=http://localhost
# Refresh token cookie domain | source: production domain | optional | default: empty
COOKIE_DOMAIN=

###############################################################################
# Encryption
###############################################################################
# Field encryption key | source: secret manager or local random value | required | default: change-me-in-production
ENCRYPTION_KEY=change-me-in-production
# Secret backend | source: choose env or vault | optional | default: env
SECRET_BACKEND=env
# Vault address | source: Vault deployment | optional | default: empty
VAULT_ADDR=
# Vault token | source: Vault auth flow | optional | default: empty
VAULT_TOKEN=

###############################################################################
# LLM Providers
###############################################################################
# Default LLM provider | source: settings UI | required | default: openai
DEFAULT_LLM_PROVIDER=openai
# Default chat model | source: provider dashboard | required | default: gpt-4.1-mini
DEFAULT_LLM_MODEL=gpt-4.1-mini
# Default embedding model | source: provider dashboard | required | default: text-embedding-3-small
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI API key | source: OpenAI project secrets | optional | default: empty
OPENAI_API_KEY=
# Anthropic API key | source: Anthropic console | optional | default: empty
ANTHROPIC_API_KEY=
# Ollama base URL | source: local Ollama service | optional | default: http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
# Langfuse host | source: Langfuse deployment | optional | default: http://langfuse:3000
LANGFUSE_HOST=http://langfuse:3000
# Langfuse public key | source: Langfuse project settings | optional | default: empty
LANGFUSE_PUBLIC_KEY=
# Langfuse secret key | source: Langfuse project settings | optional | default: empty
LANGFUSE_SECRET_KEY=

###############################################################################
# CRM Integrations
###############################################################################
# HubSpot client ID | source: HubSpot developer app | optional | default: empty
HUBSPOT_CLIENT_ID=
# HubSpot client secret | source: HubSpot developer app | optional | default: empty
HUBSPOT_CLIENT_SECRET=
# HubSpot redirect URI | source: OAuth config | optional | default: http://localhost:8000/integrations/hubspot/callback
HUBSPOT_REDIRECT_URI=http://localhost:8000/integrations/hubspot/callback
# Salesforce client ID | source: Salesforce connected app | optional | default: empty
SALESFORCE_CLIENT_ID=
# Salesforce client secret | source: Salesforce connected app | optional | default: empty
SALESFORCE_CLIENT_SECRET=

###############################################################################
# Data Enrichment
###############################################################################
# Apollo API key | source: Apollo account settings | optional | default: empty
APOLLO_API_KEY=
# Hunter API key | source: Hunter account settings | optional | default: empty
HUNTER_API_KEY=
# Enable LinkedIn scraping | source: operator preference | optional | default: false
ENABLE_LINKEDIN_SCRAPING=false

###############################################################################
# Email
###############################################################################
# Gmail client ID | source: Google Cloud console (OAuth 2.0 credential) | optional | default: empty
GMAIL_CLIENT_ID=
# Gmail client secret | source: Google Cloud console | optional | default: empty
GMAIL_CLIENT_SECRET=
# Gmail OAuth redirect URI | source: Google Cloud console authorized redirect | optional | default: http://localhost:8000/integrations/gmail/callback
GMAIL_REDIRECT_URI=http://localhost:8000/integrations/gmail/callback
# Outlook client ID | source: Azure app registration | optional | default: empty
OUTLOOK_CLIENT_ID=
# Outlook client secret | source: Azure app registration | optional | default: empty
OUTLOOK_CLIENT_SECRET=
# Outlook OAuth redirect URI | source: Azure app registration redirect URI | optional | default: http://localhost:8000/integrations/outlook/callback
OUTLOOK_REDIRECT_URI=http://localhost:8000/integrations/outlook/callback
# Default sender address | source: mailbox or sending domain | optional | default: noreply@localhost
EMAIL_FROM_ADDRESS=noreply@localhost

###############################################################################
# Notifications
###############################################################################
# Slack webhook URL | source: Slack app config | optional | default: empty
SLACK_WEBHOOK_URL=
# Generic webhook secret | source: internal integration settings | optional | default: empty
WEBHOOK_SECRET=

###############################################################################
# Observability
###############################################################################
# Log level | source: operator preference | optional | default: INFO
LOG_LEVEL=INFO
# Enable Prometheus metrics | source: operator preference | optional | default: true
ENABLE_PROMETHEUS_METRICS=true
# OpenTelemetry endpoint | source: collector or managed tracing | optional | default: empty
OTEL_EXPORTER_OTLP_ENDPOINT=
# Prometheus scrape interval in seconds | source: internal convention | optional | default: 15
PROMETHEUS_SCRAPE_INTERVAL_SECONDS=15
# Grafana admin user | source: local override | optional | default: admin
GRAFANA_ADMIN_USER=admin
# Grafana admin password | source: local override | optional | default: admin
GRAFANA_ADMIN_PASSWORD=admin
# Langfuse database URL | source: same Postgres or dedicated one | optional | default: postgresql://gtm:gtm_password@postgres:5432/langfuse
LANGFUSE_DATABASE_URL=postgresql://gtm:gtm_password@postgres:5432/langfuse
# Langfuse Redis URL | source: Redis with a separate DB index | optional | default: redis://redis:6379/1
LANGFUSE_REDIS_URL=redis://redis:6379/1
# Langfuse NextAuth URL | source: deployed URL or local compose | optional | default: http://localhost:3001
LANGFUSE_NEXTAUTH_URL=http://localhost:3001
# Langfuse NextAuth secret | source: Langfuse auth config | optional | default: change-me-in-production
LANGFUSE_NEXTAUTH_SECRET=change-me-in-production
# Langfuse salt | source: Langfuse auth config | optional | default: change-me-in-production
LANGFUSE_SALT=change-me-in-production

###############################################################################
# Frontend
###############################################################################
# Public API base URL | source: browser-facing origin | required | default: http://localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost
# Public app URL | source: browser-facing origin | required | default: http://localhost
NEXT_PUBLIC_APP_URL=http://localhost
# Public SSE URL | source: API origin | required | default: http://localhost/events/agent-status
NEXT_PUBLIC_SSE_URL=http://localhost/events/agent-status
# Disable Next.js telemetry | source: local development preference | optional | default: 1
NEXT_TELEMETRY_DISABLED=1
# Internal API URL for server-side proxying | source: Docker network service name | optional | default: http://api:8000
API_INTERNAL_URL=http://api:8000

###############################################################################
# Enterprise
###############################################################################
# Enable enterprise features | source: subscription or deployment flag | optional | default: false
ENABLE_ENTERPRISE=false
# Enterprise license key | source: licensing workflow | optional | default: empty
ENTERPRISE_LICENSE_KEY=
# Object storage endpoint | source: S3-compatible storage | optional | default: empty
OBJECT_STORAGE_ENDPOINT=
# Object storage access key | source: S3-compatible storage credentials | optional | default: empty
OBJECT_STORAGE_ACCESS_KEY_ID=
# Object storage secret key | source: S3-compatible storage credentials | optional | default: empty
OBJECT_STORAGE_SECRET_ACCESS_KEY=
# Object storage bucket | source: S3-compatible storage bucket | optional | default: gtm-engine
OBJECT_STORAGE_BUCKET=gtm-engine

